    "db:generate": "drizzle-kit generate --config drizzle.config.ts"
  },
  "dependencies": {
    "@forge/logger": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
