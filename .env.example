# FORGE — copy to .env (FORGE_* keys only)

FORGE_DISCORD_TOKEN=
FORGE_DISCORD_APPLICATION_ID=
FORGE_DISCORD_GUILD_ID=

FORGE_BITCRAFT_WS_URI=wss://bitcraft-early-access.spacetimedb.com
FORGE_BITCRAFT_MODULE=bitcraft-1
FORGE_BITCRAFT_JWT=

FORGE_DATABASE_URL=postgresql://forge:forge@localhost:5432/forge

FORGE_LOG_LEVEL=info

# Optional. When set, exposes GET /health on 0.0.0.0 (e.g. 8080 for ECS). Omit locally if unused.
# FORGE_HEALTH_PORT=8080

# Coalesce quest/barter Discord embeds per shop+quest key.
FORGE_QUEST_DISCORD_DEBOUNCE_MS=4000

# After a barter completion, suppress "Quest Updated" for that order this long (default: debounce + 3000 ms).
FORGE_QUEST_SUPPRESS_UPDATE_AFTER_COMPLETE_MS=7000

# Wait after STDB quest tables finish initial sync before posting quest embeds (replay / reconnect).
FORGE_QUEST_ANNOUNCE_AFTER_STDB_SYNC_MS=4000

FORGE_STDB_CACHE_TTL_MS=86400000

# Optional HTTPS image URL shown as a banner on /forge quest board (e.g. PNG/WebP hosted on a CDN).
# FORGE_QUEST_BOARD_BANNER_URL=
