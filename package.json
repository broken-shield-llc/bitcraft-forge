{
  "name": "bitcraft-forge",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "prepare": "node scripts/ensure-bitcraft-bindings.mjs",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "test": "pnpm -r run test",
    "start": "pnpm --filter forge start",
    "dev": "pnpm --filter forge dev",
    "db:generate": "pnpm --filter @forge/db db:generate"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "typescript-eslint": "^8.58.1"
  },
  "pnpm": {
    "patchedDependencies": {
      "@clockworklabs/spacetimedb-sdk@1.3.3": "patches/@clockworklabs__spacetimedb-sdk@1.3.3.patch"
    }
  }
}
