{
  "name": "bitcraft-forge",
  "private": true,
  "description": "Self-hosted Discord bot and read-only SpacetimeDB client for BitCraft Online — quest board, barter announcements, and Postgres-backed entity cache.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/broken-shield-llc/bitcraft-forge.git"
  },
  "homepage": "https://github.com/broken-shield-llc/bitcraft-forge#readme",
  "bugs": {
    "url": "https://github.com/broken-shield-llc/bitcraft-forge/issues"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "prepare": "node scripts/ensure-bitcraft-bindings.mjs",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "test": "pnpm -r run test",
    "start": "pnpm --filter forge start",
    "dev": "pnpm --filter forge dev",
    "db:generate": "pnpm --filter @forge/db db:generate",
    "db:migrate": "pnpm --filter forge migrate-db"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "typescript-eslint": "^8.58.2"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.4.2",
      "esbuild": "^0.25.0"
    },
    "patchedDependencies": {
      "@clockworklabs/spacetimedb-sdk@1.3.3": "patches/@clockworklabs__spacetimedb-sdk@1.3.3.patch"
    }
  }
}
