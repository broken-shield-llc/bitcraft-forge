{
  "name": "forge",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "migrate-db": "tsx scripts/migrate-db.ts"
  },
  "dependencies": {
    "@clockworklabs/spacetimedb-sdk": "1.3.3",
    "@forge/application": "workspace:*",
    "@forge/config": "workspace:*",
    "@forge/discord-forge": "workspace:*",
    "@forge/db": "workspace:*",
    "@forge/domain": "workspace:*",
    "@forge/logger": "workspace:*",
    "@forge/repos": "workspace:*",
    "discord.js": "^14.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
